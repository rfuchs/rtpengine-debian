#!/bin/bash

set -e
set -x

DISTS='forky bullseye bookworm trixie sid'
ARCHS='amd64 i386 armhf arm64'

SRCDIR=$1
test -d "$SRCDIR"
DSTDIR=$2
test -d "$DSTDIR"
TMPDIR=$3
test -d "$TMPDIR"

mv -v "$SRCDIR"/* "$TMPDIR"/ || true

for FILE in "$TMPDIR"/*; do
	BN=$(basename "$FILE")

	for ARCH in $ARCHS; do
		for DIST in $DISTS; do
			DD="$DSTDIR"/"$ARCH"/"$DIST"
			mkdir -p "$DD"
			cp -v "$FILE" "$DD"/."$BN".$$
			mv -v "$DD"/."$BN".$$ "$DD"/"$BN"
		done
	done

	rm -f "$FILE"
done
